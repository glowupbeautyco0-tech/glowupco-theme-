    {% endif %}

    {% if block.settings.item_3_date != blank %}
      <div class="ai-timeline-item-{{ ai_gen_id }}" data-timeline-item>
        <div class="ai-timeline-dot-{{ ai_gen_id }}"></div>
        <div class="ai-timeline-content-{{ ai_gen_id }}">
          <div class="ai-timeline-date-{{ ai_gen_id }}">{{ block.settings.item_3_date }}</div>
          {% if block.settings.item_3_title != blank %}
            <h3 class="ai-timeline-title-{{ ai_gen_id }}">{{ block.settings.item_3_title }}</h3>
          {% endif %}
          {% if block.settings.item_3_description != blank %}
            <div class="ai-timeline-description-{{ ai_gen_id }}">{{ block.settings.item_3_description }}</div>
          {% endif %}
        </div>
      </div>
    {% endif %}

    {% if block.settings.item_4_date != blank %}
      <div class="ai-timeline-item-{{ ai_gen_id }}" data-timeline-item>
        <div class="ai-timeline-dot-{{ ai_gen_id }}"></div>
        <div class="ai-timeline-content-{{ ai_gen_id }}">
          <div class="ai-timeline-date-{{ ai_gen_id }}">{{ block.settings.item_4_date }}</div>
          {% if block.settings.item_4_title != blank %}
            <h3 class="ai-timeline-title-{{ ai_gen_id }}">{{ block.settings.item_4_title }}</h3>
          {% endif %}
          {% if block.settings.item_4_description != blank %}
            <div class="ai-timeline-description-{{ ai_gen_id }}">{{ block.settings.item_4_description }}</div>
          {% endif %}
        </div>
      </div>
    {% endif %}

    {% if block.settings.item_5_date != blank %}
      <div class="ai-timeline-item-{{ ai_gen_id }}" data-timeline-item>
        <div class="ai-timeline-dot-{{ ai_gen_id }}"></div>
        <div class="ai-timeline-content-{{ ai_gen_id }}">
          <div class="ai-timeline-date-{{ ai_gen_id }}">{{ block.settings.item_5_date }}</div>
          {% if block.settings.item_5_title != blank %}
            <h3 class="ai-timeline-title-{{ ai_gen_id }}">{{ block.settings.item_5_title }}</h3>
          {% endif %}
          {% if block.settings.item_5_description != blank %}
            <div class="ai-timeline-description-{{ ai_gen_id }}">{{ block.settings.item_5_description }}</div>
          {% endif %}
        </div>
      </div>
    {% endif %}
  </div>
</timeline-scroll-{{ ai_gen_id }}>

<script>
  (function() {
    class TimelineScroll{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.items = [];
        this.progressLine = null;
        this.timelineLine = null;
      }

      connectedCallback() {
        this.items = Array.from(this.querySelectorAll('[data-timeline-item]'));
        this.progressLine = this.querySelector('.ai-timeline-line-progress-{{ ai_gen_id }}');
        this.timelineLine = this.querySelector('.ai-timeline-line-{{ ai_gen_id }}');
        
        if (this.items.length === 0) return;

        this.handleScroll = this.handleScroll.bind(this);
        window.addEventListener('scroll', this.handleScroll);
        window.addEventListener('resize', this.handleScroll);
        
        this.handleScroll();
      }

      disconnectedCallback() {
        window.removeEventListener('scroll', this.handleScroll);
        window.removeEventListener('resize', this.handleScroll);
      }

      handleScroll() {
        if (!this.timelineLine || this.items.length === 0) return;

        const timelineRect = this.timelineLine.getBoundingClientRect();
        const windowHeight = window.innerHeight;
        const scrollTrigger = windowHeight * 0.75;

        let activeCount = 0;
        let lastActiveItem = null;

        this.items.forEach((item, index) => {
          const itemRect = item.getBoundingClientRect();
          const itemMiddle = itemRect.top + itemRect.height / 2;

          if (itemMiddle < scrollTrigger) {
            item.classList.add('active');
            activeCount = index + 1;
            lastActiveItem = item;
          } else {
            item.classList.remove('active');
          }
        });

        if (this.progressLine && lastActiveItem) {
          const lastDot = lastActiveItem.querySelector('.ai-timeline-dot-{{ ai_gen_id }}');
          if (lastDot) {
            const dotRect = lastDot.getBoundingClientRect();
            const timelineTop = timelineRect.top;
            const dotPosition = dotRect.top - timelineTop + dotRect.height / 2;
            const percentage = (dotPosition / timelineRect.height) * 100;
            this.progressLine.style.height = Math.min(Math.max(percentage, 0), 100) + '%';
          }
        }
      }
    }

    customElements.define('timeline-scroll-{{ ai_gen_id }}', TimelineScroll{{ ai_gen_id }});
  })();
</script>

