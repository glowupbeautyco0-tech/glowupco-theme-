{% doc %}
  @prompt
    Una cronología vertical interactiva que resalta a medida que se desplaza
{% enddoc %}

{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-timeline-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    margin: 0 auto;
    padding: 60px 20px;
    background-color: {{ block.settings.background_color }};
  }

  .ai-timeline-container-{{ ai_gen_id }} {
    position: relative;
    max-width: 800px;
    margin: 0 auto;
  }

  .ai-timeline-line-{{ ai_gen_id }} {
    position: absolute;
    left: 30px;
    top: 0;
    bottom: 0;
    width: 3px;
    background-color: {{ block.settings.line_inactive_color }};
  }

  .ai-timeline-line-progress-{{ ai_gen_id }} {
    position: absolute;
    left: 0;
    top: 0;
    width: 100%;
    height: 0%;
    background-color: {{ block.settings.line_active_color }};
    transition: height 0.3s ease;
  }

  .ai-timeline-item-{{ ai_gen_id }} {
    position: relative;
    padding-left: 80px;
    margin-bottom: 60px;
    opacity: 0.4;
    transition: opacity 0.5s ease, transform 0.5s ease;
  }

  .ai-timeline-item-{{ ai_gen_id }}.active {
    opacity: 1;
    transform: translateX(0);
  }

  .ai-timeline-dot-{{ ai_gen_id }} {
    position: absolute;
    left: 21px;
    top: 8px;
    width: 18px;
    height: 18px;
    border-radius: 50%;
    background-color: {{ block.settings.dot_inactive_color }};
    border: 3px solid {{ block.settings.background_color }};
    transition: all 0.5s ease;
    z-index: 2;
  }

  .ai-timeline-item-{{ ai_gen_id }}.active .ai-timeline-dot-{{ ai_gen_id }} {
    background-color: {{ block.settings.dot_active_color }};
    transform: scale(1.4);
    box-shadow: 0 0 0 4px {{ block.settings.dot_active_color }}33;
  }

  .ai-timeline-content-{{ ai_gen_id }} {
    background-color: {{ block.settings.card_background_color }};
    padding: 24px;
    border-radius: {{ block.settings.card_border_radius }}px;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
    transition: box-shadow 0.3s ease;
  }

  .ai-timeline-item-{{ ai_gen_id }}.active .ai-timeline-content-{{ ai_gen_id }} {
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.15);
  }

  .ai-timeline-date-{{ ai_gen_id }} {
    color: {{ block.settings.date_color }};
    font-size: {{ block.settings.date_size }}px;
    font-weight: 600;
    margin-bottom: 8px;
  }

  .ai-timeline-title-{{ ai_gen_id }} {
    color: {{ block.settings.title_color }};
    font-size: {{ block.settings.title_size }}px;
    font-weight: 700;
    margin: 0 0 12px 0;
  }

  .ai-timeline-description-{{ ai_gen_id }} {
    color: {{ block.settings.text_color }};
    font-size: {{ block.settings.text_size }}px;
    line-height: 1.6;
    margin: 0;
  }

  @media screen and (max-width: 749px) {
    .ai-timeline-{{ ai_gen_id }} {
      padding: 40px 16px;
    }

    .ai-timeline-line-{{ ai_gen_id }} {
      left: 20px;
    }

    .ai-timeline-dot-{{ ai_gen_id }} {
      left: 11px;
    }

    .ai-timeline-item-{{ ai_gen_id }} {
      padding-left: 60px;
      margin-bottom: 40px;
    }

    .ai-timeline-content-{{ ai_gen_id }} {
      padding: 20px;
    }
  }
{% endstyle %}

<timeline-scroll-{{ ai_gen_id }} class="ai-timeline-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-timeline-container-{{ ai_gen_id }}">
    <div class="ai-timeline-line-{{ ai_gen_id }}">
      <div class="ai-timeline-line-progress-{{ ai_gen_id }}"></div>
    </div>

    {% if block.settings.item_1_date != blank %}
      <div class="ai-timeline-item-{{ ai_gen_id }}" data-timeline-item>
        <div class="ai-timeline-dot-{{ ai_gen_id }}"></div>
        <div class="ai-timeline-content-{{ ai_gen_id }}">
          <div class="ai-timeline-date-{{ ai_gen_id }}">{{ block.settings.item_1_date }}</div>
          {% if block.settings.item_1_title != blank %}
            <h3 class="ai-timeline-title-{{ ai_gen_id }}">{{ block.settings.item_1_title }}</h3>
          {% endif %}
          {% if block.settings.item_1_description != blank %}
            <div class="ai-timeline-description-{{ ai_gen_id }}">{{ block.settings.item_1_description }}</div>
          {% endif %}
        </div>
      </div>
    {% endif %}

    {% if block.settings.item_2_date != blank %}
